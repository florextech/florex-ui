{
  "name": "@florex/ui",
  "version": "0.1.0",
  "description": "Florex Labs shared UI library — dark-first React components and design tokens",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./florex.css": "./dist/florex.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/themes/florex.css dist/florex.css",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4",
    "@phosphor-icons/react": ">=2"
  },
  "peerDependenciesMeta": {
    "@phosphor-icons/react": { "optional": true }
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.0.2"
  },
  "devDependencies": {
    "@phosphor-icons/react": "2.1.7",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@tailwindcss/vite": "4.1.8",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "9.25.1",
    "jsdom": "26.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "storybook": "8.6.14",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.1.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/florexlabs/florex-ui"
  },
  "keywords": [
    "florex",
    "ui",
    "react",
    "tailwind",
    "design-system",
    "dark-theme"
  ]
}
